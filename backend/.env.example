DATABASE_URL=postgresql+asyncpg://advisor_user:advisor_pass@localhost:5432/academic_advisor
REDIS_URL=redis://localhost:6379
SECRET_KEY=change-this-to-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

GROQ_API_KEY=your_groq_api_key_here
GROQ_PRIMARY_MODEL=llama-3.3-70b-versatile
GROQ_FAST_MODEL=llama-3.1-8b-instant

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384
# local = sentence-transformers (PyTorch); hf = HuggingFace Inference API (no torch,
# for free-tier deploys). If hf, set HF_API_TOKEN (free at huggingface.co/settings/tokens).
EMBEDDING_BACKEND=local
HF_API_TOKEN=
# Comma-separated deployed frontend URLs allowed by CORS (Vercel *.vercel.app is
# already allowed automatically), e.g. https://aiu-advisor.vercel.app
CORS_ORIGINS=

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

LLM_CACHE_TTL_SECONDS=3600

# Stripe (TEST mode) for online tuition payments. Get a test secret key from
# https://dashboard.stripe.com/test/apikeys (hosted Checkout needs no other key).
STRIPE_SECRET_KEY=sk_test_your_test_key_here
FRONTEND_BASE_URL=http://localhost:3000
# Empty = charge in the account currency (EGP); set to usd if EGP is rejected.
STRIPE_CURRENCY=
